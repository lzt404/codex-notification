#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ENV_FILE="${CODEX_NOTIFICATION_ENV:-${HOME}/.codex/codex-notification.env}"
BIN="${CODEX_NOTIFICATION_BIN:-${PROJECT_ROOT}/bin/codex-notification}"

if [[ -f "${ENV_FILE}" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "${ENV_FILE}"
    set +a
fi

if [[ -x "${BIN}" ]]; then
    exec "${BIN}" "$@"
fi

echo "codex-notification: binary not found or not executable: ${BIN}" >&2
exit 1
