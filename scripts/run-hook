#!/usr/bin/env sh
set -eu

SCRIPT_DIR="$(CDPATH= cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ENV_FILE="${CODEX_NOTIFICATION_ENV:-${HOME}/.codex/codex-notification.env}"
BIN="${CODEX_NOTIFICATION_BIN:-${PROJECT_ROOT}/bin/codex-notification}"

trim_env_string() {
    printf '%s' "$1" | sed 's/\r$//; s/^[[:space:]]*//; s/[[:space:]]*$//'
}

convert_env_value() {
    value=
    value="$(trim_env_string "$1")"

    case "${value}" in
        \"*\")
            value=${value#\"}
            value=${value%\"}
            ;;
        \'*\')
            value=${value#\'}
            value=${value%\'}
            ;;
    esac

    printf '%s' "${value}"
}

if [ -f "${ENV_FILE}" ]; then
    while IFS= read -r line || [ -n "${line}" ]; do
        trimmed_line="$(trim_env_string "${line}")"
        case "${trimmed_line}" in
            ""|\#*) continue ;;
        esac
        case "${trimmed_line}" in
            *=*) ;;
            *) continue ;;
        esac

        name="$(trim_env_string "${trimmed_line%%=*}")"
        case "${name}" in
            ""|[0-9]*|*[!A-Za-z0-9_]*)
                continue
                ;;
        esac

        value="$(convert_env_value "${trimmed_line#*=}")"
        export "${name}=${value}"
    done < "${ENV_FILE}"
fi

export CODEX_NOTIFICATION_ENV="${ENV_FILE}"

if [ -x "${BIN}" ]; then
    exec "${BIN}" "$@"
fi

echo "codex-notification: binary not found or not executable: ${BIN}" >&2
exit 1
